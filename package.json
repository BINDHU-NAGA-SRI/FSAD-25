{
  "name": "klsubmit",
  "version": "1.0.0",
  "description": "Electronic assignment submission platform for students and teachers",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon src/index.js",
    "direct": "start chrome http://localhost:8080 && node src/index.js",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch",
    "klsubmit": "start chrome http://localhost:3000 && node src/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "tailwindcss": "^3.3.6"
  },
  "keywords": ["education", "assignments", "grading", "platform"],
  "author": "Assignment Platform Team",
  "license": "MIT"
}
